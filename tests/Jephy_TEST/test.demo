class OdomTest_t
{
private:
    /* data */
    lcm::LCM lcm;
    lcm::Subscription* odomSub;
    lcm::Subscription* filteredOdomSub;
    lcm::Subscription* laserSub;
    std::shared_ptr<XLog> xlogPtr;
    NavMsg::Odom_t odomData;
    NavMsg::Odom_t filteredOdomData, deltaFiltredOdom;
    void odomMsgUpdate(const lcm::ReceiveBuffer* rbuf, 
                        const std::string &channel, 
                        const NavMsg::Odom_t *msg)
    {
        float fTs = msg->timestamp_us / 1000000.0f;
        float wallTs = getTimeStap_us() / 1000000.0f;
        float FTs = filteredOdomData.timestamp_us/1000000.0f;
        xlogPtr->Debug("WallTs=%.4f fTs=%.4f odom(%.4f, %.4f, %.4f) deltaOdom(%.4f, %.4f, %.4f) FTs=%.4f FilteredOdom(%.4f, %.4f, %.4f) FilteredDeltaOdom(%.4f, %.4f, %.4f)", \
            wallTs, fTs, msg->px, msg->py, msg->pa, \
            odomData.px - msg->px, odomData.py - msg->py, ClipAngle(odomData.pa - msg->pa),\
            FTs, filteredOdomData.px, filteredOdomData.py, filteredOdomData.pa, \
            deltaFiltredOdom.px, deltaFiltredOdom.py, deltaFiltredOdom.pa);
        odomData = *msg;
    };

    void filteredOdomMsgUpdate(const lcm::ReceiveBuffer* rbuf, 
                        const std::string &channel, 
                        const NavMsg::Odom_t *msg)
    {
        deltaFiltredOdom.px = filteredOdomData.px - msg->px;
        deltaFiltredOdom.py = filteredOdomData.py - msg->py;
        deltaFiltredOdom.pa = ClipAngle(filteredOdomData.pa - msg->pa);
        filteredOdomData = *msg;
    }
    void laserMsgUpdate(const lcm::ReceiveBuffer* rbuf, 
                        const std::string &channel, 
                        const SensorMsg::LaserData_t *msg)
    {
        xlogPtr->Debug("Laser ts=%u ", msg->timestamp_us);
    }
public:
    OdomTest_t(std::shared_ptr<XLog> xlogPtr);
    ~OdomTest_t();
    void SetupMsg()
    {
        odomSub = lcm.subscribe(LCM_CHANNEL_RawOdom, &OdomTest_t::odomMsgUpdate, this);
        odomSub->setQueueCapacity(10);
        filteredOdomSub = lcm.subscribe(LCM_CHANNEL_Odom, &OdomTest_t::filteredOdomMsgUpdate, this);
        filteredOdomSub->setQueueCapacity(10);
        //laserSub = lcm.subscribe(LCM_CHANNEL_Laser, &OdomTest_t::laserMsgUpdate, this);
        //laserSub->setQueueCapacity(10);
    }
    void SpinOnce()
    {
        lcm.handleTimeout(1);
    }
};

OdomTest_t::OdomTest_t(std::shared_ptr<XLog> xlogPtr)
{
    this->xlogPtr = xlogPtr;
    filteredOdomData.px = 0;
    filteredOdomData.py = 0;
    filteredOdomData.pa = 0;
    deltaFiltredOdom.px = 0;
    deltaFiltredOdom.py = 0;
    deltaFiltredOdom.pa = 0;
    odomData.px = 0;
    odomData.py = 0;
    odomData.pa = 0;
    SetupMsg();
}

OdomTest_t::~OdomTest_t()
{
}

// odom Ts test
int main111(int argc, char** argv)
{
    std::shared_ptr<XLog> xlogPtr = std::make_shared<XLog>(true);
    xlogPtr->Initialise("test.log");
    xlogPtr->SetThreshold(XLOG_LEVEL::XLOG_LEVEL_INFO);
    OdomTest_t odomTest(xlogPtr);
    bindCpuCore(BIND_CPU_ID_APP);
    while (true)
    {
        /* code */
        odomTest.SpinOnce();
        sleep_ms(10);
    }
    
}

